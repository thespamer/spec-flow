{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[spec-flow] file changed — run your project test/lint command here (see AGENTS.md > Commands)'"
          }
        ]
      }
    ]
  }
}
